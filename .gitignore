# package directories
node_modules
jspm_packages

# Serverless directories
.serverless

# Dependencies
/node_modules

# Build artifacts (adjust 'dist' or 'build' to match your project's output directory)
/dist
frontend/dist
backend/dist
/build
/coverage

# Environment files
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor and OS files
.DS_Store # macOS
.vscode/ # VS Code configuration (optional, if you want to share specific workspace settings)

# TypeScript-specific
*.js # Ignore all JavaScript files generated by TypeScript (if they are in the same directory as .ts files)
!*.config.js # Do not ignore config files that are intended to be JS (e.g., tailwind.config.js)
*.d.ts # Ignore declaration files if they are generated during the build and not source-controlled

# Next.js specific
.next/
next-env.d.ts # Recommended by Next.js documentation
